---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';

const title = 'System Health | MOS';

const services = [
  { name: 'API Gateway', status: 'operational', uptime: '99.99%', response: '45ms' },
  { name: 'n8n Workflows', status: 'operational', uptime: '99.95%', response: '120ms' },
  { name: 'Database', status: 'operational', uptime: '99.99%', response: '12ms' },
  { name: 'Meta Ads API', status: 'degraded', uptime: '98.50%', response: '1.2s' },
  { name: 'Google Ads API', status: 'operational', uptime: '99.90%', response: '450ms' },
  { name: 'Notion API', status: 'operational', uptime: '99.95%', response: '280ms' },
];

const metrics = [
  { label: 'CPU Usage', value: 42, color: 'bg-blue-500' },
  { label: 'Memory', value: 68, color: 'bg-green-500' },
  { label: 'Storage', value: 78, color: 'bg-amber-500' },
  { label: 'Network', value: 35, color: 'bg-purple-500' },
];
---

<Layout title={title}>
  <div class="flex min-h-screen">
    <Sidebar role="superadmin" activePath="health" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="System Health" 
        subtitle="Monitor platform infrastructure and services"
        currentRole="superadmin"
        client:load
      />
      
      <main class="p-6">
        <!-- Status Banner -->
        <div class="mb-6 p-4 rounded-xl border bg-green-50 border-green-200 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="h-10 w-10 rounded-full bg-green-500 flex items-center justify-center">
              <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <h2 class="font-semibold text-green-900">All Systems Operational</h2>
              <p class="text-sm text-green-700">Last incident: 14 days ago</p>
            </div>
          </div>
          <div class="text-right">
            <p class="text-sm text-green-700">Platform Uptime</p>
            <p class="text-2xl font-bold text-green-900">99.99%</p>
          </div>
        </div>

        <!-- Metrics -->
        <div class="grid gap-4 md:grid-cols-4 mb-6">
          {metrics.map((metric) => (
            <div class="rounded-xl border bg-card p-4">
              <p class="text-sm text-muted-foreground">{metric.label}</p>
              <div class="mt-2 flex items-end justify-between">
                <p class="text-2xl font-bold">{metric.value}%</p>
              </div>
              <div class="mt-2 h-2 bg-secondary rounded-full overflow-hidden">
                <div class={`h-full rounded-full ${metric.color}`} style={`width: ${metric.value}%`}></div>
              </div>
            </div>
          ))}
        </div>

        <!-- Services Status -->
        <div class="rounded-xl border bg-card">
          <div class="p-4 border-b">
            <h2 class="text-lg font-semibold">Service Status</h2>
          </div>
          <div class="divide-y">
            {services.map((service) => (
              <div class="p-4 flex items-center justify-between hover:bg-muted/50">
                <div class="flex items-center gap-3">
                  <div class={`h-2.5 w-2.5 rounded-full ${
                    service.status === 'operational' ? 'bg-green-500' : 
                    service.status === 'degraded' ? 'bg-amber-500' : 'bg-red-500'
                  }`}></div>
                  <span class="font-medium">{service.name}</span>
                </div>
                <div class="flex items-center gap-6 text-sm">
                  <span class="text-muted-foreground">Uptime: {service.uptime}</span>
                  <span class="text-muted-foreground">Response: {service.response}</span>
                  <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${
                    service.status === 'operational' ? 'bg-green-100 text-green-700' : 
                    service.status === 'degraded' ? 'bg-amber-100 text-amber-700' : 'bg-red-100 text-red-700'
                  }`}>
                    {service.status}
                  </span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </main>
    </div>
  </div>
</Layout>
