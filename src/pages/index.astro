---
import Layout from '@/layouts/Layout.astro';
import KPICard from '@/components/dashboard/KPICard.vue';
import ProjectCard from '@/components/dashboard/ProjectCard.vue';
import { adminKPIs, projects, activities } from '@/data/mockData';
import { FolderKanban, Clock, CheckCircle2, Bot } from 'lucide-vue-next';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Tableau de bord', href: '/' }
];
---

<Layout title="Tableau de bord" breadcrumbs={breadcrumbs}>
  <div class="space-y-6">
    <!-- En-tête -->
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-slate-900">Tableau de bord</h1>
        <p class="text-slate-500 mt-1">Bienvenue sur votre Marketing Operating System</p>
      </div>
      <a 
        href="/projects/new" 
        class="inline-flex items-center justify-center h-10 px-4 py-2 rounded-md bg-emerald-600 text-white text-sm font-medium hover:bg-emerald-700 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
        Nouveau Projet
      </a>
    </div>

    <!-- KPIs -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      {adminKPIs.map((kpi) => (
        <KPICard 
          client:load
          label={kpi.label}
          value={kpi.value}
          trend={kpi.trend}
          trendLabel={kpi.trendLabel}
          icon={kpi.icon}
        />
      ))}
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Projets Actifs -->
      <div class="lg:col-span-2 space-y-4">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-semibold text-slate-900">Projets Actifs</h2>
          <a href="/projects" class="text-sm text-emerald-600 hover:text-emerald-700 font-medium">Voir tout</a>
        </div>
        
        <div class="grid gap-4">
          {projects.filter(p => p.status === 'active').map((project) => (
            <ProjectCard 
              client:load
              project={project}
            />
          ))}
        </div>
      </div>

      <!-- Colonne latérale -->
      <div class="space-y-6">
        <!-- Actions Rapides -->
        <div class="rounded-xl border border-slate-200 bg-white p-6">
          <h3 class="font-semibold text-slate-900 mb-4">Actions Rapides</h3>
          <div class="space-y-2">
            <a href="/agents" class="flex items-center gap-3 p-3 rounded-lg hover:bg-slate-50 transition-colors">
              <div class="p-2 bg-blue-100 rounded-lg text-blue-600">
                <Bot size={18} />
              </div>
              <div>
                <p class="font-medium text-slate-900 text-sm">Lancer un Agent</p>
                <p class="text-xs text-slate-500">9 agents disponibles</p>
              </div>
            </a>
            <a href="/validation" class="flex items-center gap-3 p-3 rounded-lg hover:bg-slate-50 transition-colors">
              <div class="p-2 bg-emerald-100 rounded-lg text-emerald-600">
                <CheckCircle2 size={18} />
              </div>
              <div>
                <p class="font-medium text-slate-900 text-sm">Validations en Attente</p>
                <p class="text-xs text-slate-500">3 éléments à valider</p>
              </div>
            </a>
            <a href="/projects" class="flex items-center gap-3 p-3 rounded-lg hover:bg-slate-50 transition-colors">
              <div class="p-2 bg-violet-100 rounded-lg text-violet-600">
                <FolderKanban size={18} />
              </div>
              <div>
                <p class="font-medium text-slate-900 text-sm">Tous les Projets</p>
                <p class="text-xs text-slate-500">4 projets au total</p>
              </div>
            </a>
          </div>
        </div>

        <!-- Activité Récente -->
        <div class="rounded-xl border border-slate-200 bg-white p-6">
          <h3 class="font-semibold text-slate-900 mb-4">Activité Récente</h3>
          <div class="space-y-4">
            {activities.slice(0, 4).map((activity) => (
              <div class="flex items-start gap-3">
                <div class={`w-8 h-8 rounded-full flex items-center justify-center text-xs ${
                  activity.type === 'agent' 
                    ? 'bg-blue-100 text-blue-600' 
                    : activity.type === 'system'
                    ? 'bg-slate-100 text-slate-600'
                    : 'bg-emerald-100 text-emerald-600'
                }`}>
                  {activity.type === 'agent' ? '🤖' : activity.user.charAt(0)}
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm text-slate-900">
                    <span class="font-medium">{activity.user}</span>
                    {' '}{activity.action}{' '}
                    <span class="text-slate-600">{activity.target}</span>
                  </p>
                  <p class="text-xs text-slate-500 flex items-center gap-1 mt-0.5">
                    <Clock size={12} />
                    {activity.time}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
