---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';
import KPICard from '@/components/dashboard/KPICard.vue';
import ProjectCard from '@/components/dashboard/ProjectCard.vue';
import ActivityFeed from '@/components/dashboard/ActivityFeed.vue';
import { adminKPIs, projects, activities } from '@/data/mockData';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Tableau de bord', href: '/' }
];
---

<Layout title="Tableau de bord">
  <div class="flex min-h-screen">
    <Sidebar role="admin" activePath="/" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Tableau de bord" 
        subtitle="Bienvenue sur votre Marketing Operating System"
        currentRole="admin"
        breadcrumbs={breadcrumbs}
        client:load
      />
      
      <main class="p-6">
        <!-- KPIs -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
          {adminKPIs.map((kpi) => (
            <KPICard 
              client:load
              label={kpi.label}
              value={kpi.value}
              trend={kpi.trend}
              trendLabel={kpi.trendLabel}
              icon={kpi.icon}
            />
          ))}
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <!-- Projets Actifs -->
          <div class="lg:col-span-2 space-y-4">
            <div class="flex items-center justify-between">
              <h2 class="text-lg font-semibold text-slate-900">Projets Actifs</h2>
              <a href="/projects" class="text-sm text-emerald-600 hover:text-emerald-700 font-medium">Voir tout</a>
            </div>
            
            <div class="grid gap-4">
              {projects.filter(p => p.status === 'active').map((project) => (
                <ProjectCard 
                  client:load
                  project={project}
                />
              ))}
            </div>
          </div>

          <!-- Colonne latérale -->
          <div class="space-y-6">
            <!-- Activité Récente -->
            <div class="rounded-xl border border-slate-200 bg-white p-6">
              <h3 class="font-semibold text-slate-900 mb-4">Activité Récente</h3>
              <ActivityFeed activities={activities} client:load />
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>
</Layout>
