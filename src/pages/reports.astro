---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';
import ReportCategoryTabs from '@/components/reports/ReportCategoryTabs.vue';

const title = 'Reports | MOS';
---

<Layout title={title}>
  <div class="flex min-h-screen">
    <Sidebar role="admin" activePath="/reports" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Reports" 
        subtitle="View and download performance reports"
        currentRole="admin"
        client:load
      />
      
      <main class="p-6">
        <ReportCategoryTabs client:load />
      </main>
    </div>
  </div>
</Layout>
