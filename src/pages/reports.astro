---
import Layout from '@/layouts/Layout.astro';
import ReportCategoryTabs from '@/components/reports/ReportCategoryTabs.vue';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Rapports', href: '/reports' }
];
---

<Layout title="Rapports" breadcrumbs={breadcrumbs}>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-slate-900">Rapports</h1>
        <p class="text-slate-500 mt-1">Consultez et téléchargez les rapports de performance</p>
      </div>
    </div>
    
    <ReportCategoryTabs client:load />
  </div>
</Layout>
