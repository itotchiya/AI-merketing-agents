---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';
import AIWorkflowDashboard from '@/components/dashboard/AIWorkflowDashboard.vue';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Workflow IA', href: '/ai-workflow' }
];
---

<Layout title="Workflow IA">
  <div class="flex min-h-screen">
    <Sidebar role="admin" activePath="/ai-workflow" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Workflow IA" 
        subtitle="Processus marketing autonome en 3 phases avec points de validation humaine"
        currentRole="admin"
        breadcrumbs={breadcrumbs}
        client:load
      />
      
      <main class="p-6">
        <AIWorkflowDashboard client:load />
      </main>
    </div>
  </div>
</Layout>
