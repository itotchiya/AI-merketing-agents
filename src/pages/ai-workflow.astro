---
import Layout from '@/layouts/Layout.astro';
import AIWorkflowDashboard from '@/components/dashboard/AIWorkflowDashboard.vue';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Workflow IA', href: '/ai-workflow' }
];
---

<Layout title="Workflow IA" breadcrumbs={breadcrumbs}>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-slate-900">Orchestration du Processus IA</h1>
        <p class="text-slate-500 mt-1">Workflow marketing autonome en 3 phases avec points de validation humaine</p>
      </div>
    </div>
    
    <AIWorkflowDashboard client:load />
  </div>
</Layout>
