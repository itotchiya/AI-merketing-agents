---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';
import ValidationTabs from '@/components/validation/ValidationTabs.vue';

const breadcrumbs = [
  { label: 'Manager', href: '/manager' },
  { label: 'Validation', href: '/manager/validation' }
];
---

<Layout title="Validation | Manager">
  <div class="flex min-h-screen">
    <Sidebar role="manager" activePath="/manager/validation" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Centre de Validation" 
        subtitle="Révisez et approuvez les productions des agents IA"
        currentRole="manager"
        breadcrumbs={breadcrumbs}
        client:load
      />
      
      <main class="p-6">
        <ValidationTabs client:load />
      </main>
    </div>
  </div>
</Layout>
