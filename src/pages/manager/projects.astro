---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';
import ProjectFilterTabs from '@/components/projects/ProjectFilterTabs.vue';

const breadcrumbs = [
  { label: 'Manager', href: '/manager' },
  { label: 'Projets', href: '/manager/projects' }
];
---

<Layout title="Projets | Manager">
  <div class="flex min-h-screen">
    <Sidebar role="manager" activePath="/manager/projects" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Mes Projets" 
        subtitle="Gérez vos projets marketing assignés"
        currentRole="manager"
        breadcrumbs={breadcrumbs}
        client:load
      />
      
      <main class="p-6">
        <ProjectFilterTabs client:load />
      </main>
    </div>
  </div>
</Layout>
