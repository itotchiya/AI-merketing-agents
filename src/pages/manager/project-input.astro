---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';

const breadcrumbs = [
  { label: 'Manager', href: '/manager' },
  { label: 'Nouveau Projet', href: '/manager/project-input' }
];

// Projects list for selection
const projects = [
  { id: 1, name: 'Lancement Été 2026', status: 'active' },
  { id: 2, name: 'Bêta Produit', status: 'active' },
  { id: 3, name: 'Newsletter T1', status: 'draft' },
];
---

<Layout title="Nouveau Projet | Manager">
  <div class="flex min-h-screen">
    <Sidebar role="manager" activePath="/manager/project-input" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Configuration Projet" 
        subtitle="Définissez les paramètres d'entrée pour les agents IA"
        currentRole="manager"
        breadcrumbs={breadcrumbs}
        client:load
      />
      
      <main class="p-6">
        <div class="max-w-4xl mx-auto">
          <!-- Progress Steps -->
          <div class="flex items-center justify-between mb-8">
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-full bg-emerald-600 text-white flex items-center justify-center text-sm font-medium">1</div>
              <span class="text-sm font-medium text-emerald-600">Informations</span>
            </div>
            <div class="flex-1 h-1 bg-slate-200 mx-4"></div>
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-full bg-slate-200 text-slate-500 flex items-center justify-center text-sm font-medium">2</div>
              <span class="text-sm text-slate-500">Objectifs</span>
            </div>
            <div class="flex-1 h-1 bg-slate-200 mx-4"></div>
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-full bg-slate-200 text-slate-500 flex items-center justify-center text-sm font-medium">3</div>
              <span class="text-sm text-slate-500">Validation</span>
            </div>
          </div>

          <form class="space-y-8">
            <!-- Section 1: Project Identity -->
            <div class="rounded-xl border border-slate-200 bg-white p-6">
              <h2 class="text-lg font-semibold text-slate-900 mb-4 flex items-center gap-2">
                <span class="w-8 h-8 rounded-lg bg-blue-100 text-blue-600 flex items-center justify-center text-sm">1</span>
                Identité du Projet
              </h2>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="md:col-span-2">
                  <label class="block text-sm font-medium text-slate-700 mb-2">
                    Nom du projet <span class="text-red-500">*</span>
                  </label>
                  <input 
                    type="text" 
                    placeholder="Ex: Lancement Été 2026"
                    class="w-full h-10 rounded-lg border border-slate-200 bg-white px-3 text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500"
                  />
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2">
                    Type de projet <span class="text-red-500">*</span>
                  </label>
                  <select class="w-full h-10 rounded-lg border border-slate-200 bg-white px-3 text-sm">
                    <option value="">Sélectionner...</option>
                    <option value="launch">Lancement produit</option>
                    <option value="awareness">Notoriété de marque</option>
                    <option value="conversion">Conversion / Ventes</option>
                    <option value="engagement">Engagement</option>
                    <option value="lead_gen">Génération de leads</option>
                    <option value="retention">Rétention client</option>
                  </select>
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2">
                    Date de lancement souhaitée
                  </label>
                  <input 
                    type="date" 
                    class="w-full h-10 rounded-lg border border-slate-200 bg-white px-3 text-sm"
                  />
                </div>
              </div>
            </div>

            <!-- Section 2: Business Objectives -->
            <div class="rounded-xl border border-slate-200 bg-white p-6">
              <h2 class="text-lg font-semibold text-slate-900 mb-4 flex items-center gap-2">
                <span class="w-8 h-8 rounded-lg bg-fuchsia-100 text-fuchsia-600 flex items-center justify-center text-sm">2</span>
                Objectifs & Budget
              </h2>
              
              <div class="space-y-6">
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2">
                    Formulation d'objectif <span class="text-red-500">*</span>
                  </label>
                  <textarea 
                    rows="3"
                    placeholder="Décrivez votre objectif principal de manière claire et mesurable..."
                    class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500"
                  ></textarea>
                  <p class="text-xs text-slate-500 mt-1">Cette description sera analysée par l'agent Étude de Marché</p>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">
                      Budget total (€) <span class="text-red-500">*</span>
                    </label>
                    <input 
                      type="number" 
                      placeholder="45000"
                      class="w-full h-10 rounded-lg border border-slate-200 bg-white px-3 text-sm"
                    />
                  </div>
                  
                  <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">
                      Durée estimée
                    </label>
                    <select class="w-full h-10 rounded-lg border border-slate-200 bg-white px-3 text-sm">
                      <option value="30">1 mois</option>
                      <option value="60">2 mois</option>
                      <option value="90" selected>3 mois (90 jours)</option>
                      <option value="180">6 mois</option>
                      <option value="365">1 an</option>
                    </select>
                  </div>
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2">
                    KPIs principaux
                  </label>
                  <div class="flex flex-wrap gap-2">
                    {['Impressions', 'Clics', 'Conversions', 'ROI', 'Engagement', 'Leads', 'Ventes'].map((kpi) => (
                      <label class="flex items-center gap-2 px-3 py-2 rounded-lg border border-slate-200 cursor-pointer hover:bg-slate-50">
                        <input type="checkbox" class="rounded text-emerald-600" />
                        <span class="text-sm">{kpi}</span>
                      </label>
                    ))}
                  </div>
                </div>
              </div>
            </div>

            <!-- Section 3: Target Audience -->
            <div class="rounded-xl border border-slate-200 bg-white p-6">
              <h2 class="text-lg font-semibold text-slate-900 mb-4 flex items-center gap-2">
                <span class="w-8 h-8 rounded-lg bg-emerald-100 text-emerald-600 flex items-center justify-center text-sm">3</span>
                Cible & Audience
              </h2>
              
              <div class="space-y-6">
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2">
                    Description de la cible <span class="text-red-500">*</span>
                  </label>
                  <textarea 
                    rows="3"
                    placeholder="Décrivez votre audience cible (âge, localisation, intérêts, comportements...)"
                    class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500"
                  ></textarea>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                  <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Tranche d'âge</label>
                    <select class="w-full h-10 rounded-lg border border-slate-200 bg-white px-3 text-sm">
                      <option value="">Sélectionner...</option>
                      <option value="18-24">18-24 ans</option>
                      <option value="25-34">25-34 ans</option>
                      <option value="35-44">35-44 ans</option>
                      <option value="45-54">45-54 ans</option>
                      <option value="55+">55+ ans</option>
                    </select>
                  </div>
                  
                  <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Localisation</label>
                    <select class="w-full h-10 rounded-lg border border-slate-200 bg-white px-3 text-sm">
                      <option value="">Sélectionner...</option>
                      <option value="france">France</option>
                      <option value="europe">Europe</option>
                      <option value="worldwide">International</option>
                    </select>
                  </div>
                  
                  <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Genre cible</label>
                    <select class="w-full h-10 rounded-lg border border-slate-200 bg-white px-3 text-sm">
                      <option value="">Tous</option>
                      <option value="homme">Homme</option>
                      <option value="femme">Femme</option>
                    </select>
                  </div>
                </div>
              </div>
            </div>

            <!-- Section 4: Requirements & Brief -->
            <div class="rounded-xl border border-slate-200 bg-white p-6">
              <h2 class="text-lg font-semibold text-slate-900 mb-4 flex items-center gap-2">
                <span class="w-8 h-8 rounded-lg bg-amber-100 text-amber-600 flex items-center justify-center text-sm">4</span>
                Cahier des Charges
              </h2>
              
              <div class="space-y-6">
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2">
                    Besoins spécifiques
                  </label>
                  <textarea 
                    rows="4"
                    placeholder="Détaillez vos besoins spécifiques, contraintes, éléments obligatoires..."
                    class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm"
                  ></textarea>
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2">
                    Canaux marketing à utiliser
                  </label>
                  <div class="flex flex-wrap gap-2">
                    {['Meta Ads', 'Google Ads', 'Email', 'LinkedIn', 'TikTok', 'YouTube', 'Site web', 'Blog'].map((channel) => (
                      <label class="flex items-center gap-2 px-3 py-2 rounded-lg border border-slate-200 cursor-pointer hover:bg-slate-50">
                        <input type="checkbox" class="rounded text-emerald-600" />
                        <span class="text-sm">{channel}</span>
                      </label>
                    ))}
                  </div>
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2">
                    Fichiers de référence
                  </label>
                  <div class="border-2 border-dashed border-slate-300 rounded-lg p-8 text-center hover:bg-slate-50 transition-colors cursor-pointer">
                    <div class="text-slate-400 mb-2">
                      <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                      </svg>
                    </div>
                    <p class="text-sm text-slate-600 font-medium">Glissez-déposez vos fichiers ici</p>
                    <p class="text-xs text-slate-500 mt-1">PDF, Word, Excel, Images (max 50MB)</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Section 5: Team Assignment -->
            <div class="rounded-xl border border-slate-200 bg-white p-6">
              <h2 class="text-lg font-semibold text-slate-900 mb-4 flex items-center gap-2">
                <span class="w-8 h-8 rounded-lg bg-violet-100 text-violet-600 flex items-center justify-center text-sm">5</span>
                Équipe & Validation
              </h2>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2">
                    Chef de projet
                  </label>
                  <select class="w-full h-10 rounded-lg border border-slate-200 bg-white px-3 text-sm">
                    <option value="">Sélectionner...</option>
                    <option value="thomas">Thomas Dubois</option>
                    <option value="marie">Marie Laurent</option>
                    <option value="sophie">Sophie Bernard</option>
                  </select>
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2">
                    Validateur
                  </label>
                  <select class="w-full h-10 rounded-lg border border-slate-200 bg-white px-3 text-sm">
                    <option value="">Sélectionner...</option>
                    <option value="thomas">Thomas Dubois</option>
                    <option value="marie">Marie Laurent</option>
                  </select>
                </div>
                
                <div class="md:col-span-2">
                  <label class="block text-sm font-medium text-slate-700 mb-2">
                    Membres de l'équipe
                  </label>
                  <div class="flex flex-wrap gap-2">
                    {['Thomas Dubois', 'Marie Laurent', 'Sophie Bernard', 'Pierre Martin', 'Lucas Bernard'].map((member) => (
                      <label class="flex items-center gap-2 px-3 py-2 rounded-lg border border-slate-200 cursor-pointer hover:bg-slate-50">
                        <input type="checkbox" class="rounded text-emerald-600" />
                        <span class="text-sm">{member}</span>
                      </label>
                    ))}
                  </div>
                </div>
              </div>
            </div>

            <!-- Actions -->
            <div class="flex items-center justify-between pt-6 border-t border-slate-200">
              <button 
                type="button"
                class="px-6 py-2 rounded-lg border border-slate-200 text-slate-700 font-medium hover:bg-slate-50 transition-colors"
              >
                Enregistrer comme brouillon
              </button>
              <div class="flex items-center gap-3">
                <button 
                  type="button"
                  class="px-6 py-2 rounded-lg border border-slate-200 text-slate-700 font-medium hover:bg-slate-50 transition-colors"
                >
                  Prévisualiser
                </button>
                <button 
                  type="submit"
                  class="px-6 py-2 rounded-lg bg-emerald-600 text-white font-medium hover:bg-emerald-700 transition-colors"
                >
                  Lancer l'étude de marché
                </button>
              </div>
            </div>
          </form>
        </div>
      </main>
    </div>
  </div>
</Layout>
