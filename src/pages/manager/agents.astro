---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';
import AgentCategoryTabs from '@/components/agents/AgentCategoryTabs.vue';

const breadcrumbs = [
  { label: 'Manager', href: '/manager' },
  { label: 'Hub Agents', href: '/manager/agents' }
];
---

<Layout title="Hub Agents | Manager">
  <div class="flex min-h-screen">
    <Sidebar role="manager" activePath="/manager/agents" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Hub Agents" 
        subtitle="Lancez et gérez les agents IA pour vos projets"
        currentRole="manager"
        breadcrumbs={breadcrumbs}
        client:load
      />
      
      <main class="p-6">
        <AgentCategoryTabs client:load />
      </main>
    </div>
  </div>
</Layout>
