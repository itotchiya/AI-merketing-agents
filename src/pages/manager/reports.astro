---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';
import ReportCategoryTabs from '@/components/reports/ReportCategoryTabs.vue';

const breadcrumbs = [
  { label: 'Manager', href: '/manager' },
  { label: 'Rapports', href: '/manager/reports' }
];
---

<Layout title="Rapports | Manager">
  <div class="flex min-h-screen">
    <Sidebar role="manager" activePath="/manager/reports" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Rapports" 
        subtitle="Consultez les rapports de performance de vos projets"
        currentRole="manager"
        breadcrumbs={breadcrumbs}
        client:load
      />
      
      <main class="p-6">
        <ReportCategoryTabs client:load />
      </main>
    </div>
  </div>
</Layout>
