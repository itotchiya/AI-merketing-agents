---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';
import TeamManager from '@/components/team/TeamManager.vue';

const breadcrumbs = [
  { label: 'Manager', href: '/manager' },
  { label: 'Équipe', href: '/manager/team' }
];
---

<Layout title="Équipe | Manager">
  <div class="flex min-h-screen">
    <Sidebar role="manager" activePath="/manager/team" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Mon Équipe" 
        subtitle="Gérez les membres de votre équipe"
        currentRole="manager"
        breadcrumbs={breadcrumbs}
        client:load
      />
      
      <main class="p-6">
        <TeamManager client:load />
      </main>
    </div>
  </div>
</Layout>
