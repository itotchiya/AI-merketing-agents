---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';
import ProjectFilterTabs from '@/components/projects/ProjectFilterTabs.vue';

const title = 'Projects | MOS';
---

<Layout title={title}>
  <div class="flex min-h-screen">
    <Sidebar role="admin" activePath="/projects" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Projects" 
        subtitle="Manage all your marketing projects"
        currentRole="admin"
        client:load
      />
      
      <main class="p-6">
        <ProjectFilterTabs client:load />
      </main>
    </div>
  </div>
</Layout>
