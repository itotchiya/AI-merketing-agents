---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';
import KPICard from '@/components/dashboard/KPICard.vue';
import ManagerViews from '@/components/manager/ManagerViews.vue';
import { managerKPIs } from '@/data/mockData';

const title = 'Manager Dashboard | MOS';
---

<Layout title={title}>
  <div class="flex min-h-screen">
    <Sidebar role="manager" activePath="/manager" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Operations Dashboard" 
        subtitle="Hello Marie! Here's your operational overview for today."
        notificationCount={2}
        currentRole="manager"
        client:load
      />
      
      <main class="p-6">
        {/* Status Banner */}
        <div class="mb-6 flex items-center gap-2">
          <div class="h-2 w-2 rounded-full bg-green-500 animate-pulse"></div>
          <span class="text-sm font-medium text-green-600">All Systems Operational</span>
        </div>

        {/* KPI Cards */}
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4 mb-8">
          {managerKPIs.map((kpi) => (
            <KPICard 
              label={kpi.label}
              value={kpi.value}
              trend={kpi.trend}
              trendLabel={kpi.trendLabel}
              icon={kpi.icon}
              client:load
            />
          ))}
        </div>

        {/* Views with Tabs */}
        <ManagerViews client:load />
      </main>
    </div>
  </div>
</Layout>
