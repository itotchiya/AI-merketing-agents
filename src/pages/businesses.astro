---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';
import BusinessManager from '@/components/businesses/BusinessManager.vue';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Entreprises', href: '/businesses' }
];
---

<Layout title="Gestion Entreprises">
  <div class="flex min-h-screen">
    <Sidebar role="superadmin" activePath="/businesses" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Gestion des Entreprises" 
        subtitle="Gérez les entreprises multi-locataires et leurs abonnements"
        currentRole="superadmin"
        breadcrumbs={breadcrumbs}
        client:load
      />
      
      <main class="p-6">
        <BusinessManager client:load />
      </main>
    </div>
  </div>
</Layout>
