---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';

const title = 'Settings | MOS';
---

<Layout title={title}>
  <div class="flex min-h-screen">
    <Sidebar role="admin" activePath="settings" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Settings" 
        subtitle="Configure your business preferences"
        currentRole="admin"
        client:load
      />
      
      <main class="p-6">
        <div class="max-w-2xl">
          {/* Business Profile */}
          <div class="rounded-xl border bg-card p-6 mb-6">
            <h2 class="text-lg font-semibold mb-4">Business Profile</h2>
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium mb-2">Company Name</label>
                <input 
                  type="text" 
                  value="Acme Corp"
                  class="w-full h-10 rounded-lg border border-input bg-background px-3 text-sm"
                />
              </div>
              <div>
                <label class="block text-sm font-medium mb-2">Website</label>
                <input 
                  type="url" 
                  value="https://acme.com"
                  class="w-full h-10 rounded-lg border border-input bg-background px-3 text-sm"
                />
              </div>
              <div>
                <label class="block text-sm font-medium mb-2">Industry</label>
                <select class="w-full h-10 rounded-lg border border-input bg-background px-3 text-sm">
                  <option>Technology / SaaS</option>
                  <option>E-commerce</option>
                  <option>Services</option>
                  <option>Other</option>
                </select>
              </div>
            </div>
          </div>

          {/* Preferences */}
          <div class="rounded-xl border bg-card p-6 mb-6">
            <h2 class="text-lg font-semibold mb-4">Preferences</h2>
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium mb-2">Default Currency</label>
                <select class="w-full h-10 rounded-lg border border-input bg-background px-3 text-sm">
                  <option>EUR (€)</option>
                  <option>USD ($)</option>
                  <option>GBP (£)</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium mb-2">Timezone</label>
                <select class="w-full h-10 rounded-lg border border-input bg-background px-3 text-sm">
                  <option>Europe/Paris (UTC+1)</option>
                  <option>America/New_York (UTC-5)</option>
                  <option>Asia/Tokyo (UTC+9)</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium mb-2">Language</label>
                <select class="w-full h-10 rounded-lg border border-input bg-background px-3 text-sm">
                  <option>English</option>
                  <option>French</option>
                  <option>Spanish</option>
                </select>
              </div>
            </div>
          </div>

          {/* Notifications */}
          <div class="rounded-xl border bg-card p-6 mb-6">
            <h2 class="text-lg font-semibold mb-4">Notifications</h2>
            <div class="space-y-3">
              <div class="flex items-center justify-between">
                <div>
                  <p class="font-medium">Email Notifications</p>
                  <p class="text-sm text-muted-foreground">Receive updates via email</p>
                </div>
                <button class="relative inline-flex h-6 w-11 items-center rounded-full bg-primary">
                  <span class="inline-block h-4 w-4 transform rounded-full bg-white translate-x-6"></span>
                </button>
              </div>
              <div class="flex items-center justify-between">
                <div>
                  <p class="font-medium">Validation Alerts</p>
                  <p class="text-sm text-muted-foreground">Get notified when items need approval</p>
                </div>
                <button class="relative inline-flex h-6 w-11 items-center rounded-full bg-primary">
                  <span class="inline-block h-4 w-4 transform rounded-full bg-white translate-x-6"></span>
                </button>
              </div>
              <div class="flex items-center justify-between">
                <div>
                  <p class="font-medium">Weekly Reports</p>
                  <p class="text-sm text-muted-foreground">Receive weekly performance summary</p>
                </div>
                <button class="relative inline-flex h-6 w-11 items-center rounded-full bg-gray-200">
                  <span class="inline-block h-4 w-4 transform rounded-full bg-white translate-x-1"></span>
                </button>
              </div>
            </div>
          </div>

          {/* Save */}
          <div class="flex justify-end">
            <button class="px-4 py-2 bg-primary text-primary-foreground rounded-lg font-medium hover:bg-primary/90">
              Save Changes
            </button>
          </div>
        </div>
      </main>
    </div>
  </div>
</Layout>
