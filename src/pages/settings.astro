---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Paramètres', href: '/settings' }
];
---

<Layout title="Paramètres">
  <div class="flex min-h-screen">
    <Sidebar role="admin" activePath="/settings" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Paramètres" 
        subtitle="Configurez les préférences de votre entreprise"
        currentRole="admin"
        breadcrumbs={breadcrumbs}
        client:load
      />
      
      <main class="p-6">
        <div class="max-w-2xl">
          {/* Business Profile */}
          <div class="rounded-xl border border-slate-200 bg-white p-6 mb-6">
            <h2 class="text-lg font-semibold mb-4">Profil Entreprise</h2>
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium mb-2">Nom de l'entreprise</label>
                <input 
                  type="text" 
                  value="Acme Corp"
                  class="w-full h-10 rounded-lg border border-slate-200 bg-white px-3 text-sm"
                />
              </div>
              <div>
                <label class="block text-sm font-medium mb-2">Site web</label>
                <input 
                  type="url" 
                  value="https://acme.com"
                  class="w-full h-10 rounded-lg border border-slate-200 bg-white px-3 text-sm"
                />
              </div>
              <div>
                <label class="block text-sm font-medium mb-2">Secteur</label>
                <select class="w-full h-10 rounded-lg border border-slate-200 bg-white px-3 text-sm">
                  <option>Technologie / SaaS</option>
                  <option>E-commerce</option>
                  <option>Services</option>
                  <option>Autre</option>
                </select>
              </div>
            </div>
          </div>

          {/* Preferences */}
          <div class="rounded-xl border border-slate-200 bg-white p-6 mb-6">
            <h2 class="text-lg font-semibold mb-4">Préférences</h2>
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium mb-2">Devise par défaut</label>
                <select class="w-full h-10 rounded-lg border border-slate-200 bg-white px-3 text-sm">
                  <option>EUR (€)</option>
                  <option>USD ($)</option>
                  <option>GBP (£)</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium mb-2">Fuseau horaire</label>
                <select class="w-full h-10 rounded-lg border border-slate-200 bg-white px-3 text-sm">
                  <option>Europe/Paris (UTC+1)</option>
                  <option>America/New_York (UTC-5)</option>
                  <option>Asia/Tokyo (UTC+9)</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium mb-2">Langue</label>
                <select class="w-full h-10 rounded-lg border border-slate-200 bg-white px-3 text-sm">
                  <option>Français</option>
                  <option>English</option>
                  <option>Español</option>
                </select>
              </div>
            </div>
          </div>

          {/* Notifications */}
          <div class="rounded-xl border border-slate-200 bg-white p-6 mb-6">
            <h2 class="text-lg font-semibold mb-4">Notifications</h2>
            <div class="space-y-3">
              <div class="flex items-center justify-between">
                <div>
                  <p class="font-medium">Notifications Email</p>
                  <p class="text-sm text-slate-500">Recevez les mises à jour par email</p>
                </div>
                <button class="relative inline-flex h-6 w-11 items-center rounded-full bg-emerald-600">
                  <span class="inline-block h-4 w-4 transform rounded-full bg-white translate-x-6"></span>
                </button>
              </div>
              <div class="flex items-center justify-between">
                <div>
                  <p class="font-medium">Alertes de Validation</p>
                  <p class="text-sm text-slate-500">Soyez notifié quand des éléments nécessitent une approbation</p>
                </div>
                <button class="relative inline-flex h-6 w-11 items-center rounded-full bg-emerald-600">
                  <span class="inline-block h-4 w-4 transform rounded-full bg-white translate-x-6"></span>
                </button>
              </div>
              <div class="flex items-center justify-between">
                <div>
                  <p class="font-medium">Rapports Hebdomadaires</p>
                  <p class="text-sm text-slate-500">Recevez le résumé de performance hebdomadaire</p>
                </div>
                <button class="relative inline-flex h-6 w-11 items-center rounded-full bg-slate-200">
                  <span class="inline-block h-4 w-4 transform rounded-full bg-white translate-x-1"></span>
                </button>
              </div>
            </div>
          </div>

          {/* Save */}
          <div class="flex justify-end">
            <button class="px-4 py-2 bg-emerald-600 text-white rounded-lg font-medium hover:bg-emerald-700 transition-colors">
              Enregistrer les Modifications
            </button>
          </div>
        </div>
      </main>
    </div>
  </div>
</Layout>
