---
import Layout from '@/layouts/Layout.astro';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Journaux d\'audit', href: '/audit' }
];

const auditEvents = [
  { id: 1, user: 'Thomas Anderson', action: 'agent.execute', target: 'Studio Créatif', time: 'il y a 2 min', severity: 'info' },
  { id: 2, user: 'Système', action: 'api.rate_limit.warning', target: 'Meta Ads API', time: 'il y a 5 min', severity: 'warning' },
  { id: 3, user: 'Marie Dubois', action: 'validation.approved', target: 'Sorties Stratégie', time: 'il y a 10 min', severity: 'success' },
  { id: 4, user: 'Pierre Martin', action: 'user.login', target: 'Chrome sur Windows', time: 'il y a 15 min', severity: 'info' },
  { id: 5, user: 'Système', action: 'agent.failed', target: 'Ads Manager', time: 'il y a 20 min', severity: 'error' },
  { id: 6, user: 'Sarah Chen', action: 'business.created', target: 'TechStart Inc', time: 'il y a 1 heure', severity: 'success' },
  { id: 7, user: 'Thomas Anderson', action: 'user.invited', target: 'newuser@example.com', time: 'il y a 2 heures', severity: 'info' },
  { id: 8, user: 'Système', action: 'backup.completed', target: 'Sauvegarde quotidienne', time: 'il y a 3 heures', severity: 'success' },
];
---

<Layout title="Journaux d'Audit" breadcrumbs={breadcrumbs}>
  <div class="space-y-6">
    {/* En-tête */}
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-slate-900">Journaux d'Audit</h1>
        <p class="text-slate-500 mt-1">Historique complet de l'activité système</p>
      </div>
    </div>

    {/* Filters */}
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-2">
        <input 
          type="date" 
          class="h-9 rounded-lg border border-slate-200 bg-white px-3 text-sm"
        />
        <span class="text-slate-500">à</span>
        <input 
          type="date" 
          class="h-9 rounded-lg border border-slate-200 bg-white px-3 text-sm"
        />
        <button class="px-4 py-2 rounded-lg bg-slate-100 text-slate-700 text-sm font-medium hover:bg-slate-200 transition-colors">
          Type d'événement
        </button>
        <button class="px-4 py-2 rounded-lg bg-slate-100 text-slate-700 text-sm font-medium hover:bg-slate-200 transition-colors">
          Gravité
        </button>
      </div>
      <button class="px-4 py-2 rounded-lg bg-slate-100 text-slate-700 text-sm font-medium flex items-center gap-2 hover:bg-slate-200 transition-colors">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        Exporter
      </button>
    </div>

    <!-- Timeline -->
    <div class="rounded-xl border border-slate-200 bg-white p-6">
      <div class="space-y-4">
        {auditEvents.map((event) => (
          <div class="flex gap-4 pb-4 border-b border-slate-100 last:border-0">
            <div class={`h-8 w-8 rounded-full flex items-center justify-center shrink-0 ${
              event.severity === 'error' ? 'bg-red-100 text-red-600' :
              event.severity === 'warning' ? 'bg-amber-100 text-amber-600' :
              event.severity === 'success' ? 'bg-emerald-100 text-emerald-600' :
              'bg-blue-100 text-blue-600'
            }`}>
              {event.severity === 'error' && <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>}
              {event.severity === 'warning' && <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>}
              {event.severity === 'success' && <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>}
              {event.severity === 'info' && <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>}
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1">
                <span class="font-medium">{event.user}</span>
                <span class="text-slate-500">→</span>
                <span class="text-slate-500">{event.action}</span>
                <span class="font-medium text-emerald-600">{event.target}</span>
              </div>
              <p class="text-xs text-slate-500">{event.time}</p>
            </div>
            <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium capitalize ${
              event.severity === 'error' ? 'bg-red-100 text-red-700' :
              event.severity === 'warning' ? 'bg-amber-100 text-amber-700' :
              event.severity === 'success' ? 'bg-emerald-100 text-emerald-700' :
              'bg-blue-100 text-blue-700'
            }`}>
              {event.severity === 'error' ? 'Erreur' :
               event.severity === 'warning' ? 'Avertissement' :
               event.severity === 'success' ? 'Succès' : 'Info'}
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>
