---
import Layout from '@/layouts/Layout.astro';
import AgentCategoryTabs from '@/components/agents/AgentCategoryTabs.vue';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Hub Agents', href: '/agents' }
];
---

<Layout title="Hub Agents" breadcrumbs={breadcrumbs}>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-slate-900">Hub Agents</h1>
        <p class="text-slate-500 mt-1">Lancez et gérez les agents IA pour vos projets</p>
      </div>
    </div>
    
    <AgentCategoryTabs client:load />
  </div>
</Layout>
