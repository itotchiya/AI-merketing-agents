---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';
import { agents } from '@/data/mockData';
import { 
  Bot, 
  Clock,
  Zap,
  BarChart3,
  Target,
  BrainCircuit,
  Megaphone,
  Image,
  Mail,
  Users,
  Share2
} from 'lucide-vue-next';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Hub Agents', href: '/agents' }
];

// Get agent-specific icon
function getAgentIcon(agentName: string) {
  if (agentName.includes('Etude') || agentName.includes('Performance')) return BarChart3;
  if (agentName.includes('Stratégie')) return Target;
  if (agentName.includes('concepteur')) return BrainCircuit;
  if (agentName.includes('Ads')) return Megaphone;
  if (agentName.includes('contenu')) return Image;
  if (agentName.includes('Email')) return Mail;
  if (agentName.includes('community')) return Users;
  if (agentName.includes('Diffusion')) return Share2;
  return Bot;
}

// Group agents by category
const agentsByCategory = {
  strategic: agents.filter(a => a.category === 'strategic'),
  operational: agents.filter(a => a.category === 'operational'),
  diffusion: agents.filter(a => a.category === 'diffusion')
};

// Color schemes
const strategicColor = 'bg-fuchsia-100 text-fuchsia-700 border-fuchsia-200';
const operationalColor = 'bg-blue-100 text-blue-700 border-blue-200';
const diffusionColor = 'bg-emerald-100 text-emerald-700 border-emerald-200';
const strategicBg = 'bg-fuchsia-50 text-fuchsia-700 border-fuchsia-200';
const operationalBg = 'bg-blue-50 text-blue-700 border-blue-200';
const diffusionBg = 'bg-emerald-50 text-emerald-700 border-emerald-200';
---

<Layout title="Hub Agents">
  <div class="flex min-h-screen">
    <Sidebar role="admin" activePath="/agents" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Hub Agents" 
        subtitle="Catalogue des agents IA du Marketing Operating System"
        currentRole="admin"
        breadcrumbs={breadcrumbs}
        client:load
      />
      
      <main class="p-6">
        {/* Strategic Agents */}
        <section class="mb-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="p-2 bg-fuchsia-100 rounded-lg">
              <BrainCircuit data-icon class="w-5 h-5 text-fuchsia-600" />
            </div>
            <div>
              <h2 class="text-lg font-semibold text-slate-900">Agents Stratégiques</h2>
              <p class="text-sm text-slate-500">Analyse, stratégie et performance</p>
            </div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {agentsByCategory.strategic.map((agent) => {
              const Icon = getAgentIcon(agent.name);
              return (
                <div class="rounded-xl border border-slate-200 bg-white p-6">
                  <div class="flex items-start gap-3 mb-4">
                    <div class={`p-2 rounded-lg ${strategicColor}`}>
                      <Icon data-icon class="w-5 h-5" />
                    </div>
                    <div>
                      <h3 class="font-semibold text-slate-900">{agent.name}</h3>
                      <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium mt-1 ${strategicBg}`}>
                        Stratégique
                      </span>
                    </div>
                  </div>
                  
                  <p class="text-sm text-slate-600 mb-4">{agent.description}</p>
                  
                  <div class="space-y-3">
                    <div>
                      <div class="text-xs text-slate-500 mb-1">Entrées</div>
                      <div class="flex flex-wrap gap-1">
                        {agent.inputs.slice(0, 3).map((input) => (
                          <span class="px-2 py-1 bg-slate-100 rounded text-xs text-slate-700">{input}</span>
                        ))}
                      </div>
                    </div>
                    
                    <div>
                      <div class="text-xs text-slate-500 mb-1">Sorties</div>
                      <div class="flex flex-wrap gap-1">
                        {agent.outputs.slice(0, 2).map((output) => (
                          <span class="px-2 py-1 bg-fuchsia-50 text-fuchsia-700 border border-fuchsia-200 rounded text-xs">{output}</span>
                        ))}
                      </div>
                    </div>
                  </div>
                  
                  <div class="flex items-center gap-1 text-xs text-slate-500 pt-4 mt-4 border-t border-slate-100">
                    <Clock data-icon class="w-3 h-3" />
                    {agent.avgTime}
                  </div>
                </div>
              );
            })}
          </div>
        </section>

        {/* Operational Agents */}
        <section class="mb-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="p-2 bg-blue-100 rounded-lg">
              <Zap data-icon class="w-5 h-5 text-blue-600" />
            </div>
            <div>
              <h2 class="text-lg font-semibold text-slate-900">Agents Opérationnels</h2>
              <p class="text-sm text-slate-500">Exécution quotidienne</p>
            </div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            {agentsByCategory.operational.map((agent) => {
              const Icon = getAgentIcon(agent.name);
              return (
                <div class="rounded-xl border border-slate-200 bg-white p-6">
                  <div class="flex items-center gap-3 mb-4">
                    <div class={`p-2 rounded-lg ${operationalColor}`}>
                      <Icon data-icon class="w-5 h-5" />
                    </div>
                    <div>
                      <h3 class="font-semibold text-slate-900">{agent.name.replace('Agent IA ', '')}</h3>
                      <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium mt-1 ${operationalBg}`}>
                        Opérationnel
                      </span>
                    </div>
                  </div>
                  
                  <p class="text-sm text-slate-600 line-clamp-2 mb-3">{agent.description}</p>
                  
                  <div class="flex flex-wrap gap-1 mb-4">
                    {agent.outputs.slice(0, 2).map((output) => (
                      <span class="px-2 py-1 bg-blue-50 text-blue-700 border border-blue-200 rounded text-xs">{output}</span>
                    ))}
                  </div>
                  
                  <div class="flex items-center gap-1 text-xs text-slate-500 pt-4 border-t border-slate-100">
                    <Clock data-icon class="w-3 h-3" />
                    Quotidien
                  </div>
                </div>
              );
            })}
          </div>
        </section>

        {/* Diffusion Agents */}
        <section>
          <div class="flex items-center gap-3 mb-4">
            <div class="p-2 bg-emerald-100 rounded-lg">
              <Share2 data-icon class="w-5 h-5 text-emerald-600" />
            </div>
            <div>
              <h2 class="text-lg font-semibold text-slate-900">Diffusion & Publication</h2>
              <p class="text-sm text-slate-500">Distribution sur tous les canaux</p>
            </div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {agentsByCategory.diffusion.map((agent) => {
              const Icon = getAgentIcon(agent.name);
              return (
                <div class="rounded-xl border border-slate-200 bg-white p-6">
                  <div class="flex items-start gap-3 mb-4">
                    <div class={`p-2 rounded-lg ${diffusionColor}`}>
                      <Icon data-icon class="w-5 h-5" />
                    </div>
                    <div>
                      <h3 class="font-semibold text-slate-900">{agent.name.replace('Agent IA ', '')}</h3>
                      <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium mt-1 ${diffusionBg}`}>
                        Diffusion
                      </span>
                    </div>
                  </div>
                  
                  <p class="text-sm text-slate-600 mb-4">{agent.description}</p>
                  
                  <div class="space-y-3">
                    <div>
                      <div class="text-xs text-slate-500 mb-1">Entrées des agents opérationnels</div>
                      <div class="flex flex-wrap gap-1">
                        <span class="px-2 py-1 bg-blue-50 text-blue-700 border border-blue-200 rounded text-xs">Ads</span>
                        <span class="px-2 py-1 bg-blue-50 text-blue-700 border border-blue-200 rounded text-xs">Contenu</span>
                        <span class="px-2 py-1 bg-blue-50 text-blue-700 border border-blue-200 rounded text-xs">Email</span>
                        <span class="px-2 py-1 bg-blue-50 text-blue-700 border border-blue-200 rounded text-xs">Community</span>
                      </div>
                    </div>
                    
                    <div>
                      <div class="text-xs text-slate-500 mb-1">Sortie</div>
                      <div class="flex flex-wrap gap-1">
                        {agent.outputs.map((output) => (
                          <span class="px-2 py-1 bg-emerald-50 text-emerald-700 border border-emerald-200 rounded text-xs">{output}</span>
                        ))}
                      </div>
                    </div>
                  </div>
                  
                  <div class="flex items-center gap-1 text-xs text-slate-500 pt-4 mt-4 border-t border-slate-100">
                    <Clock data-icon class="w-3 h-3" />
                    Exécution quotidienne
                  </div>
                </div>
              );
            })}
          </div>
        </section>
      </main>
    </div>
  </div>
</Layout>
