---
import Layout from '@/layouts/Layout.astro';
import ValidationTabs from '@/components/validation/ValidationTabs.vue';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Validation', href: '/validation' }
];
---

<Layout title="Centre de Validation" breadcrumbs={breadcrumbs}>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-slate-900">Centre de Validation</h1>
        <p class="text-slate-500 mt-1">Révisez et approuvez les productions des agents IA</p>
      </div>
    </div>
    
    <ValidationTabs client:load />
  </div>
</Layout>
