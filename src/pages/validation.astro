---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';
import ValidationTabs from '@/components/validation/ValidationTabs.vue';

const title = 'Validation Center | MOS';
---

<Layout title={title}>
  <div class="flex min-h-screen">
    <Sidebar role="admin" activePath="/validation" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Validation Center" 
        subtitle="Review and approve agent outputs"
        currentRole="admin"
        client:load
      />
      
      <main class="p-6">
        <ValidationTabs client:load />
      </main>
    </div>
  </div>
</Layout>
