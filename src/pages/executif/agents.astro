---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';
import AgentCategoryTabs from '@/components/agents/AgentCategoryTabs.vue';

const breadcrumbs = [
  { label: 'Exécutif', href: '/executif' },
  { label: 'Mes Agents', href: '/executif/agents' }
];
---

<Layout title="Mes Agents | Exécutif">
  <div class="flex min-h-screen">
    <Sidebar role="executif" activePath="/executif/agents" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Mes Agents" 
        subtitle="Agents IA disponibles pour vos tâches"
        currentRole="executif"
        breadcrumbs={breadcrumbs}
        client:load
      />
      
      <main class="p-6">
        <AgentCategoryTabs client:load />
      </main>
    </div>
  </div>
</Layout>
