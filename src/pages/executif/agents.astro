---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';
import { agents } from '@/data/mockData';
import { 
  Bot, 
  Clock,
  Zap,
  Megaphone,
  Image,
  Mail,
  Users,
  Share2
} from 'lucide-vue-next';

// Only DAILY execution agents for Executif
const dailyAgents = agents.filter(a => a.category === 'operational' || a.category === 'diffusion');

const breadcrumbs = [
  { label: 'Exécutif', href: '/executif' },
  { label: 'Mes Agents (Daily)', href: '/executif/agents' }
];

// Color schemes
const operationalColor = 'bg-blue-100 text-blue-700 border-blue-200';
const diffusionColor = 'bg-emerald-100 text-emerald-700 border-emerald-200';
const operationalBg = 'bg-blue-50 text-blue-700 border-blue-200';
const diffusionBg = 'bg-emerald-50 text-emerald-700 border-emerald-200';

function getAgentIcon(agentName: string) {
  if (agentName.includes('Ads')) return Megaphone;
  if (agentName.includes('contenu')) return Image;
  if (agentName.includes('Email')) return Mail;
  if (agentName.includes('community')) return Users;
  if (agentName.includes('Diffusion')) return Share2;
  return Bot;
}
---

<Layout title="Mes Agents | Exécutif">
  <div class="flex min-h-screen">
    <Sidebar role="executif" activePath="/executif/agents" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Mes Agents (Daily)" 
        subtitle="Agents d'exécution quotidienne sous votre responsabilité"
        currentRole="executif"
        breadcrumbs={breadcrumbs}
        client:load
      />
      
      <main class="p-6">
        {/* Info Banner */}
        <div class="mb-6 p-4 rounded-lg bg-blue-50 border border-blue-200">
          <div class="flex items-start gap-3">
            <svg class="h-5 w-5 text-blue-600 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
              <p class="font-medium text-blue-900">Votre périmètre d'action</p>
              <p class="text-sm text-blue-700">Vous supervisez uniquement les agents d'exécution quotidienne (Phase 3). Les agents stratégiques (Étude de Marché, Stratégie) et le Concepteur Opérationnel sont gérés par votre manager.</p>
            </div>
          </div>
        </div>

        {/* Daily Execution Agents */}
        <div class="mb-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="p-2 bg-blue-100 rounded-lg">
              <Zap data-icon class="w-5 h-5 text-blue-600" />
            </div>
            <div>
              <h2 class="text-lg font-semibold text-slate-900">Agents Opérationnels Quotidiens</h2>
              <p class="text-sm text-slate-500">Exécution quotidienne sous votre supervision</p>
            </div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            {dailyAgents.filter(a => a.category === 'operational').map((agent) => {
              const Icon = getAgentIcon(agent.name);
              return (
                <div class="rounded-xl border border-slate-200 bg-white p-6">
                  <div class="flex items-center gap-3 mb-4">
                    <div class={`p-2 rounded-lg ${operationalColor}`}>
                      <Icon data-icon class="w-5 h-5" />
                    </div>
                    <div>
                      <h3 class="font-semibold text-slate-900">{agent.name.replace('Agent IA ', '')}</h3>
                      <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium mt-1 ${operationalBg}`}>
                        Opérationnel
                      </span>
                    </div>
                  </div>
                  
                  <p class="text-sm text-slate-600 line-clamp-2 mb-3">{agent.description}</p>
                  
                  <div class="flex flex-wrap gap-1 mb-4">
                    {agent.outputs.slice(0, 2).map((output) => (
                      <span class="px-2 py-1 bg-blue-50 text-blue-700 border border-blue-200 rounded text-xs">{output}</span>
                    ))}
                  </div>
                  
                  <div class="flex items-center gap-1 text-xs text-slate-500 pt-4 border-t border-slate-100">
                    <Clock data-icon class="w-3 h-3" />
                    Exécution quotidienne
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        {/* Diffusion Agent */}
        <div>
          <div class="flex items-center gap-3 mb-4">
            <div class="p-2 bg-emerald-100 rounded-lg">
              <Share2 data-icon class="w-5 h-5 text-emerald-600" />
            </div>
            <div>
              <h2 class="text-lg font-semibold text-slate-900">Agent de Diffusion</h2>
              <p class="text-sm text-slate-500">Publication sur tous les canaux</p>
            </div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {dailyAgents.filter(a => a.category === 'diffusion').map((agent) => {
              const Icon = getAgentIcon(agent.name);
              return (
                <div class="rounded-xl border border-slate-200 bg-white p-6">
                  <div class="flex items-start gap-3 mb-4">
                    <div class={`p-2 rounded-lg ${diffusionColor}`}>
                      <Icon data-icon class="w-5 h-5" />
                    </div>
                    <div>
                      <h3 class="font-semibold text-slate-900">{agent.name.replace('Agent IA ', '')}</h3>
                      <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium mt-1 ${diffusionBg}`}>
                        Diffusion
                      </span>
                    </div>
                  </div>
                  
                  <p class="text-sm text-slate-600 mb-4">{agent.description}</p>
                  
                  <div class="space-y-3">
                    <div>
                      <div class="text-xs text-slate-500 mb-1">Reçoit les contenus de :</div>
                      <div class="flex flex-wrap gap-1">
                        <span class="px-2 py-1 bg-blue-50 text-blue-700 border border-blue-200 rounded text-xs">Ads</span>
                        <span class="px-2 py-1 bg-blue-50 text-blue-700 border border-blue-200 rounded text-xs">Contenu</span>
                        <span class="px-2 py-1 bg-blue-50 text-blue-700 border border-blue-200 rounded text-xs">Email</span>
                        <span class="px-2 py-1 bg-blue-50 text-blue-700 border border-blue-200 rounded text-xs">Community</span>
                      </div>
                    </div>
                  </div>
                  
                  <div class="flex items-center gap-1 text-xs text-slate-500 pt-4 mt-4 border-t border-slate-100">
                    <Clock data-icon class="w-3 h-3" />
                    Publication quotidienne
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        {/* Workflow Info */}
        <div class="mt-8 p-6 rounded-xl border border-slate-200 bg-slate-50">
          <h3 class="font-semibold text-slate-900 mb-2">Votre rôle dans le workflow</h3>
          <p class="text-sm text-slate-600 mb-4">
            En tant qu'Exécutif, vous intervenez uniquement dans la <strong>Phase 3 : Exécution Quotidienne</strong>. 
            Vous validez les productions des agents quotidiens avant leur publication.
          </p>
          <div class="flex items-center gap-4 text-sm">
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 rounded-full bg-fuchsia-500"></div>
              <span class="text-slate-500">Phase 1 & 2 : Manager</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 rounded-full bg-blue-500"></div>
              <span class="text-slate-900 font-medium">Phase 3 : Vous (Exécutif)</span>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>
</Layout>
