---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';

const breadcrumbs = [
  { label: 'Exécutif', href: '/executif' },
  { label: 'Paramètres', href: '/executif/settings' }
];
---

<Layout title="Paramètres | Exécutif">
  <div class="flex min-h-screen">
    <Sidebar role="executif" activePath="/executif/settings" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Paramètres" 
        subtitle="Configurez vos préférences"
        currentRole="executif"
        breadcrumbs={breadcrumbs}
        client:load
      />
      
      <main class="p-6">
        <div class="max-w-2xl">
          <div class="rounded-xl border border-slate-200 bg-white p-6 mb-6">
            <h2 class="text-lg font-semibold mb-4">Préférences Personnelles</h2>
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium mb-2">Langue</label>
                <select class="w-full h-10 rounded-lg border border-slate-200 bg-white px-3 text-sm">
                  <option>Français</option>
                  <option>English</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium mb-2">Notifications</label>
                <div class="space-y-2">
                  <label class="flex items-center gap-2">
                    <input type="checkbox" checked class="rounded" />
                    <span class="text-sm">Nouvelles tâches assignées</span>
                  </label>
                  <label class="flex items-center gap-2">
                    <input type="checkbox" checked class="rounded" />
                    <span class="text-sm">Rappels de deadlines</span>
                  </label>
                </div>
              </div>
            </div>
          </div>
          
          <div class="flex justify-end">
            <button class="px-4 py-2 bg-emerald-600 text-white rounded-lg font-medium hover:bg-emerald-700 transition-colors">
              Enregistrer
            </button>
          </div>
        </div>
      </main>
    </div>
  </div>
</Layout>
