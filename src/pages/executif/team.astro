---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';
import TeamManager from '@/components/team/TeamManager.vue';

const breadcrumbs = [
  { label: 'Exécutif', href: '/executif' },
  { label: 'Équipe', href: '/executif/team' }
];
---

<Layout title="Équipe | Exécutif">
  <div class="flex min-h-screen">
    <Sidebar role="executif" activePath="/executif/team" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Mon Équipe" 
        subtitle="Membres de l'équipe"
        currentRole="executif"
        breadcrumbs={breadcrumbs}
        client:load
      />
      
      <main class="p-6">
        <TeamManager client:load />
      </main>
    </div>
  </div>
</Layout>
