---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';
import KPICard from '@/components/dashboard/KPICard.vue';
import { executifKPIs } from '@/data/mockData';

const breadcrumbs = [
  { label: 'Exécutif', href: '/executif' },
  { label: 'Mes Stats', href: '/executif/stats' }
];

const dailyTasks = [
  { day: 'Lun', completed: 8, total: 10 },
  { day: 'Mar', completed: 10, total: 10 },
  { day: 'Mer', completed: 7, total: 9 },
  { day: 'Jeu', completed: 9, total: 10 },
  { day: 'Ven', completed: 6, total: 8 },
  { day: 'Sam', completed: 4, total: 5 },
  { day: 'Dim', completed: 3, total: 4 },
];
---

<Layout title="Mes Stats | Exécutif">
  <div class="flex min-h-screen">
    <Sidebar role="executif" activePath="/executif/stats" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Mes Statistiques" 
        subtitle="Performance de vos validations quotidiennes"
        currentRole="executif"
        breadcrumbs={breadcrumbs}
        client:load
      />
      
      <main class="p-6">
        {/* KPIs */}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
          {executifKPIs.map((kpi) => (
            <KPICard 
              label={kpi.label}
              value={kpi.value}
              trend={kpi.trend}
              trendLabel={kpi.trendLabel}
              icon={kpi.icon}
              client:load
            />
          ))}
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          {/* Weekly Activity */}
          <div class="rounded-xl border border-slate-200 bg-white p-6">
            <h3 class="font-semibold text-slate-900 mb-4">Activité Hebdomadaire</h3>
            <div class="flex items-end justify-between h-48 gap-2">
              {dailyTasks.map((day) => (
                <div class="flex-1 flex flex-col items-center gap-2">
                  <div class="w-full flex flex-col-reverse gap-1">
                    <div 
                      class="w-full bg-emerald-200 rounded-t"
                      style={`height: ${(day.completed / day.total) * 100}px`}
                    ></div>
                  </div>
                  <span class="text-xs text-slate-500">{day.day}</span>
                  <span class="text-xs font-medium text-emerald-600">{day.completed}/{day.total}</span>
                </div>
              ))}
            </div>
          </div>

          {/* Agent Breakdown */}
          <div class="rounded-xl border border-slate-200 bg-white p-6">
            <h3 class="font-semibold text-slate-900 mb-4">Validations par Agent</h3>
            <div class="space-y-4">
              <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-lg bg-blue-100 flex items-center justify-center text-blue-600">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
                    </svg>
                  </div>
                  <span class="font-medium">Ads Manager</span>
                </div>
                <span class="text-sm text-slate-600">24 validés cette semaine</span>
              </div>
              
              <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-lg bg-blue-100 flex items-center justify-center text-blue-600">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </div>
                  <span class="font-medium">Création de contenu</span>
                </div>
                <span class="text-sm text-slate-600">18 validés cette semaine</span>
              </div>
              
              <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-lg bg-blue-100 flex items-center justify-center text-blue-600">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                  </div>
                  <span class="font-medium">Email Marketing</span>
                </div>
                <span class="text-sm text-slate-600">12 validés cette semaine</span>
              </div>
              
              <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-lg bg-blue-100 flex items-center justify-center text-blue-600">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                    </svg>
                  </div>
                  <span class="font-medium">Community Manager</span>
                </div>
                <span class="text-sm text-slate-600">31 validés cette semaine</span>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>
</Layout>
