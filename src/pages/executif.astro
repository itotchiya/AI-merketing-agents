---
import Layout from '@/layouts/Layout.astro';
import KPICard from '@/components/dashboard/KPICard.vue';
import ExecutifViews from '@/components/executif/ExecutifViews.vue';
import { executifKPIs } from '@/data/mockData';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Espace de Travail', href: '/executif' }
];
---

<Layout title="Mon Espace de Travail" breadcrumbs={breadcrumbs}>
  <div class="space-y-6">
    {/* En-tête */}
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-slate-900">Mon Espace de Travail</h1>
        <p class="text-slate-500 mt-1">Bonjour Pierre ! Voici votre focus pour aujourd'hui.</p>
      </div>
    </div>

    {/* KPI Cards */}
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {executifKPIs.map((kpi) => (
        <KPICard 
          label={kpi.label}
          value={kpi.value}
          trend={kpi.trend}
          trendLabel={kpi.trendLabel}
          icon={kpi.icon}
          client:load
        />
      ))}
    </div>

    {/* Views with Tabs */}
    <ExecutifViews client:load />
  </div>
</Layout>
