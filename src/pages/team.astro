---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';
import TeamManager from '@/components/team/TeamManager.vue';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Équipe', href: '/team' }
];
---

<Layout title="Gestion Équipe">
  <div class="flex min-h-screen">
    <Sidebar role="admin" activePath="/team" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Gestion de l'Équipe" 
        subtitle="Gérez les membres de l'équipe et leurs permissions"
        currentRole="admin"
        breadcrumbs={breadcrumbs}
        client:load
      />
      
      <main class="p-6">
        <TeamManager client:load />
      </main>
    </div>
  </div>
</Layout>
