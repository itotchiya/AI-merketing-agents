---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';
import TeamManager from '@/components/team/TeamManager.vue';

const title = 'Team | MOS';
---

<Layout title={title}>
  <div class="flex min-h-screen">
    <Sidebar role="admin" activePath="/team" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Team Management" 
        subtitle="Manage team members and their permissions"
        currentRole="admin"
        client:load
      />
      
      <main class="p-6">
        <TeamManager client:load />
      </main>
    </div>
  </div>
</Layout>
