---
import Layout from '@/layouts/Layout.astro';
import TeamManager from '@/components/team/TeamManager.vue';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Équipe', href: '/team' }
];
---

<Layout title="Gestion Équipe" breadcrumbs={breadcrumbs}>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-slate-900">Gestion de l'Équipe</h1>
        <p class="text-slate-500 mt-1">Gérez les membres de l'équipe et leurs permissions</p>
      </div>
    </div>
    
    <TeamManager client:load />
  </div>
</Layout>
