---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/layout/Sidebar.vue';
import Header from '@/components/layout/Header.vue';

const breadcrumbs = [
  { label: 'SuperAdmin', href: '/superadmin' },
  { label: 'Paramètres', href: '/superadmin/settings' }
];
---

<Layout title="Paramètres | SuperAdmin">
  <div class="flex min-h-screen">
    <Sidebar role="superadmin" activePath="/superadmin/settings" client:load />
    
    <div class="ml-60 flex-1">
      <Header 
        title="Paramètres Plateforme" 
        subtitle="Configuration globale du système"
        currentRole="superadmin"
        breadcrumbs={breadcrumbs}
        client:load
      />
      
      <main class="p-6">
        <div class="max-w-2xl">
          <!-- Platform Settings -->
          <div class="rounded-xl border border-slate-200 bg-white p-6 mb-6">
            <h2 class="text-lg font-semibold mb-4">Configuration Plateforme</h2>
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium mb-2">Nom de la plateforme</label>
                <input 
                  type="text" 
                  value="MOS - Marketing Operating System"
                  class="w-full h-10 rounded-lg border border-slate-200 bg-white px-3 text-sm"
                />
              </div>
              <div>
                <label class="block text-sm font-medium mb-2">Email de support</label>
                <input 
                  type="email" 
                  value="support@mos.ai"
                  class="w-full h-10 rounded-lg border border-slate-200 bg-white px-3 text-sm"
                />
              </div>
              <div>
                <label class="block text-sm font-medium mb-2">Mode maintenance</label>
                <div class="flex items-center gap-3">
                  <button class="relative inline-flex h-6 w-11 items-center rounded-full bg-slate-200">
                    <span class="inline-block h-4 w-4 transform rounded-full bg-white translate-x-1"></span>
                  </button>
                  <span class="text-sm text-slate-500">Désactivé</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Security -->
          <div class="rounded-xl border border-slate-200 bg-white p-6 mb-6">
            <h2 class="text-lg font-semibold mb-4">Sécurité</h2>
            <div class="space-y-4">
              <div class="flex items-center justify-between">
                <div>
                  <p class="font-medium">Authentification à deux facteurs</p>
                  <p class="text-sm text-slate-500">Obligatoire pour tous les utilisateurs</p>
                </div>
                <button class="relative inline-flex h-6 w-11 items-center rounded-full bg-emerald-600">
                  <span class="inline-block h-4 w-4 transform rounded-full bg-white translate-x-6"></span>
                </button>
              </div>
            </div>
          </div>

          <!-- Save -->
          <div class="flex justify-end">
            <button class="px-4 py-2 bg-emerald-600 text-white rounded-lg font-medium hover:bg-emerald-700 transition-colors">
              Enregistrer les Modifications
            </button>
          </div>
        </div>
      </main>
    </div>
  </div>
</Layout>
